// Soapfactory database schema — SQLite (dev) / Postgres (prod-ready)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id @default(cuid())
  wooId     Int?       @unique          // original WooCommerce id (for parent mapping)
  name      String
  nameEn    String?    // optional English name — shown when the EN toggle is on
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children  Category[] @relation("Subcategories")
  products  Product[]  @relation("ProductCategories")
  createdAt DateTime   @default(now())
}

model Product {
  id               String      @id @default(cuid())
  sku              String?     @unique
  name             String
  slug             String      @unique
  price            Float
  currency         String      @default("EUR")
  onSale           Boolean     @default(false)
  inStock          Boolean     @default(true)
  stockQty         Int?        // null = untracked (use inStock flag); a number = tracked stock that auto-decrements
  shortDescription String?
  description       String?
  // Optional English translations — shown on the storefront when the EN
  // language toggle is on; fall back to the Bulgarian fields when empty.
  nameEn           String?
  shortDescriptionEn String?
  descriptionEn    String?
  weight           String?
  images           String      @default("[]") // JSON-encoded array of image URLs
  hoverImage       String?     // second photo cross-faded in when the product card is hovered
  featured         Boolean     @default(false)
  categories       Category[]  @relation("ProductCategories")
  orderItems       OrderItem[]
  reviews          Review[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([createdAt])   // admin + catalog list ordering
  @@index([featured])    // featured products on the homepage
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  rating     Int      // 1–5
  comment    String?
  approved   Boolean  @default(false) // admin moderates before it shows publicly
  verified   Boolean  @default(false) // reviewer's account has an order containing this product
  createdAt  DateTime @default(now())

  @@index([productId])  // reviews-for-a-product lookups (FK)
  @@index([approved])   // pending-moderation badge + admin tabs
}

model User {
  id           String    @id @default(cuid())
  wpId         Int?      @unique          // original WordPress user id
  email        String    @unique
  name         String?
  passwordHash String                     // WordPress hash ($P$/$wp$) or our bcrypt
  hashType     String    @default("bcrypt") // "phpass" | "wp" | "bcrypt"
  role         String    @default("user")   // "user" | "admin"
  phone        String?
  address      String?
  city         String?
  postcode     String?
  country      String?
  // Bumped on password change / reset to invalidate all previously-issued
  // session tokens (each token carries the version it was signed with).
  sessionVersion Int     @default(0)
  createdAt    DateTime  @default(now())
  orders       Order[]
  sessions     Session[]
}

// Auth.js-compatible session store
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])  // session lookups for a user (FK)
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          String      @default("new") // new|processing|shipped|delivered|cancelled
  customerName    String
  email           String
  phone           String
  city            String
  postcode        String?
  address         String
  notes           String?
  subtotal        Float
  shipping        Float       @default(0)
  total           Float
  paymentMethod   String      @default("cod")     // cod | stripe
  paymentStatus   String      @default("pending") // pending | paid | failed
  stripeSessionId String?
  // ── Shipping / courier ──────────────────────────────────────────────
  courier         String?     // "econt" | "speedy"
  deliveryType    String?     // "office" | "address"
  officeCode      String?     // courier office id (when delivering to an office)
  officeName      String?     // human-readable office label, e.g. "Econt София Витоша"
  trackingNumber  String?     // courier shipment number once a label is created
  labelUrl        String?     // URL/Reference of the generated shipping label (PDF)
  confirmationSentAt DateTime? // when the confirmation email was sent (prevents duplicates)
  discountCode    String?     // promo code applied (if any)
  discountAmount  Float       @default(0) // discount value in EUR applied to this order
  source          String?     // attribution: where the customer came from (e.g. "Facebook (реклама)")
  utmCampaign     String?     // ad campaign name, if tagged
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([createdAt])      // list ordering (admin lists, dashboard)
  @@index([status])         // status tabs + "new orders" badge/count
  @@index([paymentStatus])  // dashboard paid-revenue aggregate
  @@index([userId])         // a customer's order history (FK)
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int

  @@index([orderId])    // items-of-an-order (FK)
  @@index([productId])  // best-sellers aggregate (FK)
}

// Promo / discount codes
model Discount {
  id          String    @id @default(cuid())
  code        String    @unique          // stored uppercase, e.g. WELCOME10
  type        String    @default("percent") // "percent" | "fixed"
  value       Float                       // 10 = 10% (percent) or 10 € (fixed)
  active      Boolean   @default(true)
  minSubtotal Float?                      // minimum order subtotal to qualify
  maxUses     Int?                        // total allowed uses (null = unlimited)
  usedCount   Int       @default(0)
  expiresAt   DateTime?                   // optional expiry
  createdAt   DateTime  @default(now())
}

// Blog posts ("Полезно")
model Post {
  id          String   @id @default(cuid())
  wpId        Int?     @unique          // original WordPress post id (for migration)
  title       String
  slug        String   @unique
  excerpt     String?
  content     String                    // HTML body
  // Optional English version — shown when the EN toggle is on; falls back to BG.
  titleEn     String?
  excerptEn   String?
  contentEn   String?                   // HTML body (EN)
  coverImage  String?
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Pending email-verification signups. A real User row is NOT created until the
// 6-digit code emailed at signup is confirmed — so unconfirmed signups never
// exist as users. One row per email (re-registering overwrites it).
model PendingSignup {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  code         String    // 6-digit confirmation code
  expiresAt    DateTime  // code TTL (15 min)
  attempts     Int       @default(0) // wrong-code attempts (locks after a few)
  // ── Per-email resend throttle (escalating cooldown: 60s → 120s → 6h lock) ──
  resendCount  Int       @default(0) // how many times a code has been re-sent
  lastSentAt   DateTime  @default(now()) // when the last code was emailed
  lockedUntil  DateTime? // set when the escalation trips a long lockout
  createdAt    DateTime  @default(now())
}

// Per-IP signup throttle log — one row per code actually emailed, used to cap
// how many new signups a single IP can trigger per hour (anti-flood).
model SignupIpLog {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// Throttle log for password-reset requests. One row per *attempt* (whether or
// not the email belongs to a real user), so the rate limit is enforced BEFORE
// user existence is checked and can never be used to probe which emails exist.
model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String   // normalized email (may not correspond to a real user)
  ip        String
  sent      Boolean  @default(false) // true only when a reset email actually went out
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// Password reset tokens (1-hour TTL, single-use)
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// Newsletter subscribers
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  subscribedAt DateTime @default(now())
}

// Lightweight first-party analytics (no 3rd-party tracker)
model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  sessionId   String?  // anonymous visitor id (cookie)
  utmSource   String?  // e.g. facebook, instagram, tiktok, google
  utmMedium   String?  // e.g. cpc, paid, social, email
  utmCampaign String?  // e.g. spring_sale
  createdAt   DateTime @default(now())

  @@index([createdAt])  // analytics date-range filtering (fastest-growing table)
  @@index([sessionId])  // unique-visitor counting
}
